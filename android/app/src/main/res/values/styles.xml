<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ============================================================ -->
    <!-- Text Appearances                                              -->
    <!-- ============================================================ -->

    <!-- Fraunces heading: 36sp, medium weight -->
    <style name="TextAppearance.Manuscripta.Heading" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/fraunces_medium</item>
        <item name="android:textSize">36sp</item>
        <item name="android:textColor">@color/eink_black</item>
    </style>

    <!-- IBM Plex Sans body: 30sp, regular weight -->
    <style name="TextAppearance.Manuscripta.Body" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/ibm_plex_sans</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textColor">@color/eink_black</item>
    </style>

    <!-- IBM Plex Sans body small: 20sp -->
    <style name="TextAppearance.Manuscripta.Body.Small" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/ibm_plex_sans</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/eink_black</item>
    </style>

    <!-- ============================================================ -->
    <!-- Widget Styles                                                 -->
    <!-- ============================================================ -->

    <!-- Standard button: eink_light bg, 4dp eink_black border, bold text -->
    <style name="Widget.Manuscripta.Button" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button</item>
        <item name="android:fontFamily">@font/ibm_plex_sans_bold</item>
        <item name="android:textColor">@color/eink_black</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Submit button: full-width variant with min-height 60dp -->
    <style name="Widget.Manuscripta.Button.Submit" parent="Widget.Manuscripta.Button">
        <item name="android:minHeight">60dp</item>
        <item name="android:layout_width">match_parent</item>
    </style>

    <!-- Tab button: bold text, 4dp border -->
    <style name="Widget.Manuscripta.Tab" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_tab_inactive</item>
        <item name="android:fontFamily">@font/ibm_plex_sans_bold</item>
        <item name="android:textColor">@color/eink_black</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Active tab: eink_light background with underline -->
    <style name="Widget.Manuscripta.Tab.Active" parent="Widget.Manuscripta.Tab">
        <item name="android:background">@drawable/bg_tab_active</item>
    </style>

    <!-- Card container: eink_light bg, 4dp black border, 24dp padding -->
    <style name="Widget.Manuscripta.Card" parent="">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">24dp</item>
    </style>

</resources>
