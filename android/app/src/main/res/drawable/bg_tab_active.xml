<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background fill -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/eink_light" />
            <stroke
                android:width="4dp"
                android:color="@color/eink_black" />
        </shape>
    </item>
    <!-- Bottom underline indicator for active tab -->
    <item android:gravity="bottom">
        <shape android:shape="rectangle">
            <solid android:color="@color/eink_black" />
            <size android:height="4dp" />
        </shape>
    </item>
</layer-list>
