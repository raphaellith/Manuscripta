<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="android.widget.FrameLayout">

    <!-- Character image button -->
    <ImageButton
        android:id="@+id/mascotButton"
        android:layout_width="@dimen/mascot_size"
        android:layout_height="@dimen/mascot_size"
        android:layout_gravity="bottom|start"
        android:background="@android:color/transparent"
        android:contentDescription="@string/cd_mascot"
        android:scaleType="fitCenter"
        android:src="@drawable/char_swirlok" />

    <!-- Dialogue popup (menu with Simplify/Summarise) -->
    <LinearLayout
        android:id="@+id/dialoguePopup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="112dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_dialogue"
        android:elevation="8dp"
        android:minWidth="200dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/dialogueTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/ai_how_can_i_help"
            android:textColor="@color/eink_black"
            android:textSize="@dimen/text_body_small"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/simplifyButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dialogue_action"
                android:paddingLeft="16dp"
                android:paddingTop="8dp"
                android:paddingRight="16dp"
                android:paddingBottom="8dp"
                android:text="@string/ai_simplify"
                android:textAllCaps="false"
                android:textColor="@color/eink_black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/summariseButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_dialogue_action"
                android:paddingLeft="16dp"
                android:paddingTop="8dp"
                android:paddingRight="16dp"
                android:paddingBottom="8dp"
                android:text="@string/ai_summarise"
                android:textAllCaps="false"
                android:textColor="@color/eink_black"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</merge>
