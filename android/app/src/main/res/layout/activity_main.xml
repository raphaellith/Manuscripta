<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/padding_screen"
    tools:context=".ui.main.MainActivity">

    <!-- Tab bar -->
    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/tabReading"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_active"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:text="@string/tab_reading"
            android:textAllCaps="false"
            android:textColor="@color/eink_black"
            android:textSize="@dimen/text_tab"
            android:textStyle="bold" />

        <Button
            android:id="@+id/tabQuiz"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_inactive"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:text="@string/tab_quiz"
            android:textAllCaps="false"
            android:textColor="@color/eink_black"
            android:textSize="@dimen/text_tab"
            android:textStyle="bold" />

        <Button
            android:id="@+id/tabWorksheet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_inactive"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:text="@string/tab_worksheet"
            android:textAllCaps="false"
            android:textColor="@color/eink_black"
            android:textSize="@dimen/text_tab"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Fragment container -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- AI Response Panel (above footer, hidden by default) -->
    <com.manuscripta.student.ui.view.AiResponsePanelView
        android:id="@+id/aiResponsePanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Footer -->
    <FrameLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:orientation="horizontal">

            <!-- Mascot assistant (left side) -->
            <com.manuscripta.student.ui.view.MascotAssistantView
                android:id="@+id/mascotView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <!-- Audio button (right side) -->
            <com.manuscripta.student.ui.view.AudioButtonView
                android:id="@+id/audioButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|bottom" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
