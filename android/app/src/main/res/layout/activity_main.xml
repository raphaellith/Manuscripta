<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.main.MainActivity">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/padding_screen">

    <!-- Material title header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/materialDropdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="16dp"
                android:text="@string/materials_menu"
                android:textColor="@color/eink_black"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/fraunces_bold" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="16dp"
                android:contentDescription="@string/materials_menu"
                android:src="@drawable/ic_dropdown_arrow" />

        </FrameLayout>

        <View
            android:id="@+id/separator"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/eink_black" />

    </LinearLayout>

    <!-- Fragment container -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- AI Response Panel (above footer, hidden by default) -->
    <com.manuscripta.student.ui.view.AiResponsePanelView
        android:id="@+id/aiResponsePanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Teacher Feedback Panel (above footer, hidden by default) -->
    <com.manuscripta.student.ui.view.TeacherFeedbackPanelView
        android:id="@+id/teacherFeedbackPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Footer -->
    <FrameLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start|bottom"
            android:orientation="horizontal">

            <Button
                android:id="@+id/footerSubmitButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|bottom"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_button"
                android:minHeight="@dimen/button_back_min_height"
                android:paddingLeft="24dp"
                android:paddingTop="12dp"
                android:paddingRight="24dp"
                android:paddingBottom="12dp"
                android:text="@string/submit_answer"
                android:textAllCaps="false"
                android:textColor="@color/eink_black"
                android:textSize="@dimen/text_body_small"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/raiseHandButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|bottom"
                android:background="@drawable/bg_raise_hand"
                android:textAllCaps="false"
                android:textColor="@color/eink_dark"
                android:textSize="14sp"
                android:fontFamily="@font/ibm_plex_sans"
                android:text="@string/raise_hand" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>

<!-- Lock overlay (hidden by default) -->
<LinearLayout
    android:id="@+id/lockOverlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center"
    android:orientation="vertical"
    android:visibility="gone">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/screen_locked"
        android:textColor="@android:color/white"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/screen_locked_message"
        android:textColor="@android:color/white"
        android:textSize="18sp" />

</LinearLayout>

</FrameLayout>
